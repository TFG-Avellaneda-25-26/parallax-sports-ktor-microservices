<configuration>
    <property scope="context" name="appName" value="${SERVICE_NAME:-parallax-ktor}"/>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>alertId</includeMdcKeyName>
            <includeMdcKeyName>workerId</includeMdcKeyName>
            <includeMdcKeyName>channel</includeMdcKeyName>
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <customFields>{"app":"${appName}"}</customFields>
        </encoder>
    </appender>

    <logger name="org.koin" level="ERROR"/>
    <logger name="net.dv8tion.jda" level="WARN"/>
    <logger name="io.netty" level="WARN"/>
    <logger name="org.eclipse.jetty" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
